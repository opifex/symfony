{
    "type": "object",
    "properties": {
        "access_token": {
            "type": "string",
            "pattern": "^[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+$"
        },
        "token_type": {
            "type": "string",
            "enum": [
                "Bearer"
            ]
        },
        "expires_in": {
            "type": "integer",
            "minimum": 1
        }
    },
    "required": [
        "access_token",
        "token_type",
        "expires_in"
    ],
    "additionalProperties": false
}
